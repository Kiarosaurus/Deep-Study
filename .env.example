# =============================================================================
# DeepStudy — environment configuration
#
# Copy this file to `.env` at the project root and fill in the required values.
# `docker compose up` reads `.env` automatically; the manual (non-Docker) flow
# loads it via `python-dotenv` in main.py.
# =============================================================================


# -----------------------------------------------------------------------------
# REQUIRED
# -----------------------------------------------------------------------------

# Google Gemini API key — used for both the global document map and the
# per-paragraph explanations. Obtain from https://aistudio.google.com/apikey
# Backend refuses to start without this set.
GEMINI_API_KEY=


# -----------------------------------------------------------------------------
# BACKEND — optional
# -----------------------------------------------------------------------------

# Python logging level for the backend process and its workers.
# Accepted values: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# DEBUG is verbose; use it to trace extraction / batch-planner / marker_worker
# decisions on stderr.
DEEPSTUDY_LOG_LEVEL=INFO

# How many Marker extractions are allowed to run in parallel inside the
# backend process. Marker loads multi-GB of weights and saturates either VRAM
# (CUDA) or one CPU core per Surya batch, so concurrent uploads can OOM the
# host. Bumping above 1 only makes sense on machines with very large RAM/VRAM.
DEEPSTUDY_EXTRACT_PARALLEL=1

# Verbose tracing of the continuation-paragraph merge pass in extraction.py
# (logs every chain decision). Set to 1 only when debugging cross-page /
# cross-column paragraph fusion.
DEEPSTUDY_CONT_DEBUG=0


# -----------------------------------------------------------------------------
# FRONTEND — optional, build-time
# -----------------------------------------------------------------------------

# Bake the `flag_sentence` diagnostic logger into the frontend bundle so the
# browser console shows the per-stage highlight resolution trace
# (handleExplain.input / llmResponse / aligned / resolveSentenceIndices /
# alignExplanations.resolved / LinearReader.highlight / PdfViewer.highlight).
# Used to triage why a highlight covers the sentences it does.
#
# When unset, you can still toggle the logs at runtime from DevTools:
#   localStorage.setItem('flag_sentence', '1')   # persistent per browser
#   window.flag_sentence = true                  # one-shot, lost on reload
#
# Set to 1 here to enable for everyone using the built bundle.
VITE_FLAG_SENTENCE=


# -----------------------------------------------------------------------------
# ADVANCED — Marker / Surya tunables (rarely needed)
# -----------------------------------------------------------------------------
#
# These are normally auto-derived by `batch_planner.env_overrides_for_batch`
# from system metrics (free RAM / VRAM) and adjusted per chunk. Set them here
# ONLY to override that auto-tuning — e.g. to force a specific device or to
# cap memory usage tighter than the planner chose. Uncomment to use.
#
# Device backend for the Surya models. `cuda` requires NVIDIA + the NVIDIA
# Container Toolkit when running inside Docker. `mps` is Apple Silicon. `cpu`
# is the default fallback.
# TORCH_DEVICE=cuda
# TORCH_DEVICE_MODEL=cuda
#
# Per-stage batch sizes. The Surya-prefixed variants exist because newer
# Surya versions renamed the variables; setting both keeps either version
# happy. RECOGNITION dominates peak VRAM (autoregressive decode), so cap it
# tighter than the others on small GPUs.
# RECOGNITION_BATCH_SIZE=1
# DETECTOR_BATCH_SIZE=2
# LAYOUT_BATCH_SIZE=2
# ORDER_BATCH_SIZE=4
# TEXIFY_BATCH_SIZE=1
# TABLE_REC_BATCH_SIZE=2
# OCR_ERROR_BATCH_SIZE=2
# SURYA_RECOGNITION_BATCH_SIZE=1
# SURYA_DETECTOR_BATCH_SIZE=2
# SURYA_LAYOUT_BATCH_SIZE=2
# SURYA_ORDER_BATCH_SIZE=4
